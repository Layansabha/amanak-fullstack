<?xml version="1.0" encoding="utf-8"?>

<resources>
    <style name="welcome">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#385D94</item>
    </style>
    <style name="enter_your_">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#737373</item>
    </style>
    <style name="small_label">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#A3A3A3</item>
    </style>


        <!-- Base application theme -->
        <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
            <!-- Customize your theme here -->
            <item name="colorPrimary">@color/colorPrimary</item>
            <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
            <item name="colorAccent">@color/colorAccent</item>
        </style>

        <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
        <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

        <style name="DrawerMenuRow">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">53dp</item>
            <item name="android:clickable">true</item>
            <item name="android:focusable">true</item>
            <item name="android:foreground">?android:attr/selectableItemBackground</item>
            <item name="android:gravity">center_vertical</item>
            <item name="android:orientation">horizontal</item>
            <item name="android:paddingStart">21dp</item>
            <item name="android:paddingEnd">16dp</item>
        </style>

        <style name="DrawerMenuIcon">
            <item name="android:layout_width">22dp</item>
            <item name="android:layout_height">22dp</item>
        </style>

        <style name="DrawerMenuText">
            <item name="android:layout_width">wrap_content</item>
            <item name="android:layout_height">wrap_content</item>
            <item name="android:layout_marginStart">14dp</item>
            <item name="android:fontFamily">@font/poppins</item>
            <item name="android:textColor">#385D94</item>
            <item name="android:textSize">14sp</item>
        </style>

        <style name="AmanakBottomNavigationStyle">
            <item name="android:layout_width">match_parent</item>
            <item name="android:layout_height">72dp</item>
            <item name="android:layout_marginStart">8dp</item>
            <item name="android:layout_marginEnd">8dp</item>
            <item name="android:layout_marginBottom">8dp</item>
            <item name="android:background">@drawable/home_bottom_nav_background</item>
            <item name="android:elevation">8dp</item>
            <item name="itemIconTint">@null</item>
            <item name="itemTextColor">@null</item>
            <item name="itemIconSize">26dp</item>
            <item name="itemRippleColor">@android:color/transparent</item>
            <item name="itemHorizontalTranslationEnabled">false</item>
            <item name="labelVisibilityMode">unlabeled</item>
        </style>


</resources>
