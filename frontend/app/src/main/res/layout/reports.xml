<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent"
    android:layout_height="match_parent" android:background="@drawable/fullback">
    <include android:id="@+id/reportHeader" layout="@layout/report_header"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent" />
    <ScrollView android:id="@+id/reportStepOneScroll" android:layout_width="0dp" android:layout_height="0dp"
        android:fillViewport="true" android:clipToPadding="false" android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/reportHeader" app:layout_constraintBottom_toTopOf="@id/reportFooter"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical"
            android:paddingStart="17dp" android:paddingEnd="17dp" android:paddingBottom="12dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="@font/poppins"
                android:text="Discover and Select 🔎" android:textColor="#385D94" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="@font/poppins"
                android:text="The type of cybercrime you are facing" android:textColor="#222222" android:textSize="16sp" />
            <LinearLayout android:id="@+id/cybercrimeDropdown" android:layout_width="match_parent" android:layout_height="57dp"
                android:layout_marginTop="18dp" android:layout_marginBottom="20dp" android:background="@drawable/report_input_background"
                android:clickable="true" android:focusable="true" android:gravity="center_vertical" android:paddingStart="16dp" android:paddingEnd="13dp">
                <TextView android:id="@+id/cybercrimeDropdownText" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:fontFamily="@font/poppins" android:text="Type Of cybercrime" android:textColor="#A8A8AA" android:textSize="14sp" />
                <ImageView android:layout_width="25dp" android:layout_height="25dp" android:src="@drawable/ic_report_chevron" android:contentDescription="Select" />
            </LinearLayout>
            <include android:id="@+id/linearLayout_fraud" layout="@layout/item_cybercrime_option" />
            <include android:id="@+id/linearLayout_extortion" layout="@layout/item_cybercrime_option" />
            <include android:id="@+id/linearLayout_harassment" layout="@layout/item_cybercrime_option" />
            <include android:id="@+id/linearLayout_hacking" layout="@layout/item_cybercrime_option" />
            <include android:id="@+id/linearLayout_defamation" layout="@layout/item_cybercrime_option" />
            <include android:id="@+id/linearLayout_impersonation" layout="@layout/item_cybercrime_option" />
        </LinearLayout>
    </ScrollView>
    <LinearLayout android:id="@+id/reportFooter" android:layout_width="0dp" android:layout_height="82dp"
        android:background="@drawable/report_footer_background" android:gravity="center_vertical" android:orientation="horizontal"
        android:paddingStart="49dp" android:paddingEnd="25dp" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:fontFamily="@font/poppins" android:text="1 of 3" android:textColor="#1F2730" android:textSize="14sp" />
        <TextView android:id="@+id/nextButton" android:layout_width="193dp" android:layout_height="51dp"
            android:background="@drawable/report_primary_button" android:clickable="true" android:focusable="true"
            android:fontFamily="@font/poppins" android:gravity="center" android:text="Next" android:textColor="#FFFFFF" android:textStyle="bold" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
