<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="#385D93"
    android:fillViewport="true"
    tools:context=".third">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="640dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/secpic"
            android:layout_width="0dp"
            android:layout_height="360dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="20dp"
            android:adjustViewBounds="true"
            android:scaleType="fitCenter"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/secpic" />

        <ImageView
            android:id="@+id/imageView15"
            android:layout_width="0dp"
            android:layout_height="280dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="20dp"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/secpic"
            app:srcCompat="@drawable/conn2" />

        <ImageView
            android:id="@+id/third"
            android:layout_width="74dp"
            android:layout_height="22dp"
            android:layout_marginTop="40dp"
            app:layout_constraintEnd_toEndOf="@id/imageView15"
            app:layout_constraintStart_toStartOf="@id/imageView15"
            app:layout_constraintTop_toTopOf="@id/imageView15"
            app:srcCompat="@drawable/third" />

        <TextView
            android:id="@+id/textView9"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="32dp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:text="@string/casee"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            app:layout_constraintEnd_toEndOf="@id/imageView15"
            app:layout_constraintStart_toStartOf="@id/imageView15"
            app:layout_constraintTop_toBottomOf="@id/third" />

        <TextView
            android:id="@+id/textView10"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="32dp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:text="@string/caseee"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="@id/imageView15"
            app:layout_constraintStart_toStartOf="@id/imageView15"
            app:layout_constraintTop_toBottomOf="@id/textView9" />

        <ImageView
            android:id="@+id/imageView18"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginTop="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageView15"
            app:srcCompat="@drawable/first_btn" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
