<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:minHeight="126dp" android:layout_marginBottom="12dp"
    android:background="@drawable/report_card_background" android:clickable="true"
    android:focusable="true" android:gravity="center_vertical" android:orientation="horizontal">
    <ImageView android:id="@+id/crimeOptionIcon" android:layout_width="64dp" android:layout_height="64dp"
        android:layout_marginEnd="14dp" android:scaleType="fitCenter" android:contentDescription="Cybercrime type" />
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/crimeOptionTitle" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:fontFamily="@font/poppins" android:textColor="#222222" android:textSize="16sp" android:textStyle="bold" />
        <TextView android:id="@+id/crimeOptionDescription" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="3dp" android:fontFamily="@font/poppins" android:lineSpacingExtra="2dp"
            android:textColor="#666666" android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
