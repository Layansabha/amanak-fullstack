<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    android:overScrollMode="never">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="780dp"
        android:paddingBottom="18dp">

        <ImageView
            android:id="@+id/onboardingImage"
            android:layout_width="0dp"
            android:layout_height="422dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="10dp"
            android:adjustViewBounds="true"
            android:contentDescription="Onboarding feature"
            android:scaleType="fitXY"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/onboardingCard"
            android:layout_width="0dp"
            android:layout_height="290dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="10dp"
            android:contentDescription="@null"
            android:scaleType="fitXY"
            android:src="@drawable/conn2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/onboardingImage" />

        <LinearLayout
            android:id="@+id/onboardingDots"
            android:layout_width="wrap_content"
            android:layout_height="18dp"
            android:layout_marginTop="34dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="@id/onboardingCard"
            app:layout_constraintStart_toStartOf="@id/onboardingCard"
            app:layout_constraintTop_toTopOf="@id/onboardingCard">

            <View
                android:id="@+id/onboardingDotOne"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/onboarding_dot_inactive" />

            <View
                android:id="@+id/onboardingDotTwo"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/onboarding_dot_inactive" />

            <View
                android:id="@+id/onboardingDotThree"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/onboarding_dot_inactive" />
        </LinearLayout>

        <TextView
            android:id="@+id/onboardingTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="28dp"
            android:layout_marginTop="18dp"
            android:layout_marginEnd="28dp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="27sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/onboardingCard"
            app:layout_constraintStart_toStartOf="@id/onboardingCard"
            app:layout_constraintTop_toBottomOf="@id/onboardingDots" />

        <TextView
            android:id="@+id/onboardingDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="40dp"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:lineSpacingExtra="5dp"
            android:maxLines="5"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:layout_constraintEnd_toEndOf="@id/onboardingCard"
            app:layout_constraintStart_toStartOf="@id/onboardingCard"
            app:layout_constraintTop_toBottomOf="@id/onboardingTitle" />

        <ImageView
            android:id="@+id/onboardingNextButton"
            android:layout_width="74dp"
            android:layout_height="74dp"
            android:layout_marginTop="-36dp"
            android:clickable="true"
            android:contentDescription="Next"
            android:focusable="true"
            android:src="@drawable/first_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/onboardingCard" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
