<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/buttonn"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    tools:context=".OtpActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="640dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/imageView2"
            android:layout_width="0dp"
            android:layout_height="220dp"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/cir1" />

        <TextView
            android:id="@+id/amanak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="88dp"
            android:fontFamily="@font/poppins"
            android:shadowColor="#40000000"
            android:shadowDx="0"
            android:shadowDy="4"
            android:shadowRadius="4"
            android:text="@string/amanak"
            android:textColor="#385D94"
            android:textSize="52sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="24dp"
            android:padding="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageView2"
            app:srcCompat="@drawable/back" />

        <TextView
            android:id="@+id/textView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="40dp"
            android:fontFamily="@font/poppins"
            android:text="@string/forgot"
            android:textColor="#385D94"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageView" />

        <TextView
            android:id="@+id/textView6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="40dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="40dp"
            android:fontFamily="@font/poppins"
            android:text="@string/we"
            android:textColor="#737373"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView" />

        <EditText
            android:id="@+id/otp1"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/rounded_corner_view"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColorHint="#A3A3A3"
            android:textSize="18sp"
            app:layout_constraintEnd_toStartOf="@id/otp2"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView6" />

        <EditText
            android:id="@+id/otp2"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/rounded_corner_view"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColorHint="#A3A3A3"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@id/otp1"
            app:layout_constraintEnd_toStartOf="@id/otp3"
            app:layout_constraintStart_toEndOf="@id/otp1"
            app:layout_constraintTop_toTopOf="@id/otp1" />

        <EditText
            android:id="@+id/otp3"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/rounded_corner_view"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColorHint="#A3A3A3"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@id/otp1"
            app:layout_constraintEnd_toStartOf="@id/otp4"
            app:layout_constraintStart_toEndOf="@id/otp2"
            app:layout_constraintTop_toTopOf="@id/otp1" />

        <EditText
            android:id="@+id/otp4"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="40dp"
            android:background="@drawable/rounded_corner_view"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:inputType="number"
            android:maxLength="1"
            android:textColorHint="#A3A3A3"
            android:textSize="18sp"
            app:layout_constraintBottom_toBottomOf="@id/otp1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/otp3"
            app:layout_constraintTop_toTopOf="@id/otp1" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="40dp"
            android:layout_marginTop="24dp"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="@font/poppins"
            android:gravity="center_vertical"
            android:text="@string/res"
            android:textColor="#385D94"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/timerText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/otp1" />

        <TextView
            android:id="@+id/timerText"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginEnd="40dp"
            android:fontFamily="@font/poppins"
            android:gravity="center_vertical"
            android:text="0:59"
            android:textColor="#385D94"
            android:textStyle="bold"
            app:layout_constraintBaseline_toBaselineOf="@id/textView7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/textView7" />

        <Button
            android:id="@+id/button"
            android:layout_width="193dp"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#385D94"
            android:fontFamily="@font/poppins"
            android:text="@string/verfiy"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            app:cornerRadius="50dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView7" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
