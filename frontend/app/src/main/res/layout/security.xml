<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/secback"
    android:fillViewport="true"
    tools:context=".SecuritySettingsActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="760dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/back_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="28dp"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@drawable/arrow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textView17"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:gravity="center"
            android:text="@string/secpas"
            android:textColor="#000000"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="@id/back_button"
            app:layout_constraintEnd_toStartOf="@id/imageView24"
            app:layout_constraintStart_toEndOf="@id/back_button"
            app:layout_constraintTop_toTopOf="@id/back_button" />

        <ImageView
            android:id="@+id/imageView24"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="28dp"
            android:layout_marginEnd="16dp"
            android:padding="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/notification" />

        <TextView
            android:id="@+id/textView30"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="72dp"
            android:layout_marginEnd="48dp"
            android:fontFamily="@font/poppins"
            android:text="@string/seacc"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView17" />

        <TextView
            android:id="@+id/textView31"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="48dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="48dp"
            android:fontFamily="@font/poppins"
            android:text="@string/show"
            android:textColor="#C2D8FA"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView30" />

        <ImageView
            android:id="@+id/imageView32"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintEnd_toStartOf="@id/imageView41"
            app:layout_constraintHorizontal_chainStyle="spread"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView31"
            app:srcCompat="@drawable/face" />

        <ImageView
            android:id="@+id/imageView41"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="24dp"
            app:layout_constraintBottom_toBottomOf="@id/imageView32"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/imageView32"
            app:layout_constraintTop_toTopOf="@id/imageView32"
            app:srcCompat="@drawable/auth" />

        <TextView
            android:id="@+id/textView3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/poppins"
            android:text="@string/enable"
            android:textColor="#385D94"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/imageView32"
            app:layout_constraintStart_toStartOf="@id/imageView32"
            app:layout_constraintTop_toTopOf="@id/imageView32" />

        <TextView
            android:id="@+id/textView33"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/poppins"
            android:text="@string/bio"
            android:textColor="#000000"
            app:layout_constraintBottom_toTopOf="@id/switch2"
            app:layout_constraintEnd_toEndOf="@id/imageView32"
            app:layout_constraintStart_toStartOf="@id/imageView32" />

        <Switch
            android:id="@+id/switch2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="@id/imageView32"
            app:layout_constraintStart_toStartOf="@id/textView33" />

        <TextView
            android:id="@+id/textView32"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="48dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/poppins"
            android:text="@string/enable"
            android:textColor="#385D94"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="@id/imageView41"
            app:layout_constraintStart_toStartOf="@id/imageView41"
            app:layout_constraintTop_toTopOf="@id/imageView41" />

        <TextView
            android:id="@+id/textView34"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/poppins"
            android:text="@string/loginotp"
            android:textColor="#000000"
            app:layout_constraintBottom_toTopOf="@id/switch3"
            app:layout_constraintEnd_toEndOf="@id/imageView41"
            app:layout_constraintStart_toStartOf="@id/imageView41" />

        <Switch
            android:id="@+id/switch3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toBottomOf="@id/imageView41"
            app:layout_constraintStart_toStartOf="@id/textView34" />

        <TextView
            android:id="@+id/textView35"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="30dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="30dp"
            android:fontFamily="@font/poppins"
            android:text="@string/change"
            android:textColor="#000000"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageView32" />

        <EditText
            android:id="@+id/oldpass"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/edittext_border"
            android:drawableStart="@drawable/lockk"
            android:drawablePadding="10dp"
            android:fontFamily="@font/poppins"
            android:hint="@string/oldpass"
            android:inputType="textPassword"
            android:paddingStart="10dp"
            android:paddingEnd="52dp"
            android:textColorHint="#A3A3A3"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textView35" />

        <ImageView
            android:id="@+id/eye_icon1"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_eye"
            app:layout_constraintBottom_toBottomOf="@id/oldpass"
            app:layout_constraintEnd_toEndOf="@id/oldpass"
            app:layout_constraintHorizontal_bias="0.95"
            app:layout_constraintStart_toStartOf="@id/oldpass"
            app:layout_constraintTop_toTopOf="@id/oldpass" />

        <EditText
            android:id="@+id/newpass"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/edittext_border"
            android:drawableStart="@drawable/lock"
            android:drawablePadding="10dp"
            android:fontFamily="@font/poppins"
            android:hint="@string/pass1"
            android:inputType="textPassword"
            android:paddingStart="10dp"
            android:paddingEnd="52dp"
            android:textColorHint="#A3A3A3"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/oldpass" />

        <ImageView
            android:id="@+id/eye_icon11"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_eye"
            app:layout_constraintBottom_toBottomOf="@id/newpass"
            app:layout_constraintEnd_toEndOf="@id/newpass"
            app:layout_constraintHorizontal_bias="0.95"
            app:layout_constraintStart_toStartOf="@id/newpass"
            app:layout_constraintTop_toTopOf="@id/newpass" />

        <EditText
            android:id="@+id/newpass2"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="30dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="30dp"
            android:background="@drawable/edittext_border"
            android:drawableStart="@drawable/lock"
            android:drawablePadding="10dp"
            android:fontFamily="@font/poppins"
            android:hint="@string/pass2"
            android:inputType="textPassword"
            android:paddingStart="10dp"
            android:paddingEnd="52dp"
            android:textColorHint="#A3A3A3"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/newpass" />

        <ImageView
            android:id="@+id/eye_icon12"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:clickable="true"
            android:focusable="true"
            android:src="@drawable/ic_eye"
            app:layout_constraintBottom_toBottomOf="@id/newpass2"
            app:layout_constraintEnd_toEndOf="@id/newpass2"
            app:layout_constraintHorizontal_bias="0.95"
            app:layout_constraintStart_toStartOf="@id/newpass2"
            app:layout_constraintTop_toTopOf="@id/newpass2" />

        <ImageView
            android:id="@+id/imageView48"
            android:layout_width="142dp"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/newpass2"
            app:srcCompat="@drawable/changebtn" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
